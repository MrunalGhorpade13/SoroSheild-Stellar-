# SoroShield Environment Variables Configuration

# Stellar network to use: 'testnet' or 'mainnet'
VITE_STELLAR_NETWORK=testnet

# Stellar Horizon API endpoint
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint
VITE_SOROBAN_RPC=https://soroban-testnet.stellar.org

# The deployed SoroShield Soroban contract ID
VITE_CONTRACT_ID=CB7Y7UI...

# SoroShield Treasury address where the scan fees are transferred
VITE_TREASURY_WALLET=GBA234...

# Sponsor secret key used for wrapping first-time scans in fee bumps (Backend only)
# KEEP THIS SECRET AND NEVER EXPOSE TO CLIENT/FRONTEND BUNDLES!
FEE_BUMP_SECRET=SB2345...

# API Port
PORT=3001
